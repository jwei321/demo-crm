# Copy to .env and fill in. Never commit .env.

# --- Stage 1: discovery sources ---
# Hunter.io API key (https://hunter.io/api-keys)
HUNTER_API_KEY=

# Apollo.io API key (https://app.apollo.io/#/settings/integrations/api)
APOLLO_API_KEY=

# --- Stage 2+ : Microsoft Graph / Outlook sending (added in a later stage) ---
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=

# --- General ---
# Path to the SQLite database file (defaults to ./data/prospecting.db)
DATABASE_PATH=./data/prospecting.db

# Your business identity, required in every outbound email footer (Spam Control Act)
# SENDER_NAME=
# SENDER_COMPANY=
# SENDER_BUSINESS_ADDRESS=
