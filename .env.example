# PostgreSQL connection string
# Local example:  postgresql://postgres:postgres@localhost:5432/demo_crm
# Railway will inject this automatically when you attach a Postgres plugin.
DATABASE_URL="postgresql://user:password@host:5432/demo_crm"

# Secret used to sign login session cookies (JWT). REQUIRED in production.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# Optional: credentials for the seeded demo account (npm run db:seed).
# DEMO_EMAIL="demo@relay.app"
# DEMO_PASSWORD="relay1234"
